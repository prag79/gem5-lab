#!/usr/bin/env bash
# /usr/local/bin/lab - dispatcher for the gem5 starter exercises.
# Usage: lab {list|01|02|03|shell}

set -e

LABS_ROOT="${LABS_ROOT:-/labs}"

cmd="${1:-list}"; shift || true

case "$cmd" in
  list|"")
    echo "Available labs:"
    for d in "$LABS_ROOT"/*/; do
      echo "  $(basename "$d")"
    done
    echo
    echo "Run with: lab 01 | lab 02 | lab 03"
    ;;

  01|01-se-hello)
    cd "$LABS_ROOT/01-se-hello"
    make
    exec gem5-riscv run-se.py hello-se.elf
    ;;

  02|02-fs-linux-riscv)
    echo "Booting Linux on HiFive (FS mode)."
    echo "When you see 'Listening for system connection on port 3456',"
    echo "open a SECOND terminal in this Codespace and run:"
    echo
    echo "    telnet localhost 3456"
    echo
    exec gem5-riscv /opt/gem5/configs/example/gem5_library/riscv-fs.py
    ;;

  03|03-cpu-comparison)
    cd "$LABS_ROOT/03-cpu-comparison"
    exec python3 compare.py
    ;;

  shell|repl)
    exec bash
    ;;

  -h|--help|help)
    echo "usage: lab {list|01|02|03|shell}"
    ;;

  *)
    echo "lab: unknown command '$cmd'" >&2
    echo "usage: lab {list|01|02|03|shell}" >&2
    exit 1
    ;;
esac
