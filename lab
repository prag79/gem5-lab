#!/usr/bin/env bash
# /usr/local/bin/lab - dispatcher for the gem5 starter exercises.
# Usage: lab {list|01|02|03|shell}

set -e

LABS_ROOT="${LABS_ROOT:-/labs}"
WORK_ROOT="${WORK_ROOT:-$HOME/work}"

# Mirror a canonical lab dir from $LABS_ROOT (root-owned, read-only) into
# the user's writable work tree, then cd into it. Using `cp -ru` is
# idempotent: re-running `lab N` won't clobber the student's edits, but
# will pull in any new files added upstream.
prepare_workdir() {
  local lab="$1"
  local src="$LABS_ROOT/$lab"
  local dst="$WORK_ROOT/$lab"
  if [ ! -d "$src" ]; then
    echo "lab: no such lab '$lab' under $LABS_ROOT" >&2
    exit 1
  fi
  mkdir -p "$dst"
  cp -ru "$src/." "$dst/"
  cd "$dst"
}

cmd="${1:-list}"; shift || true

case "$cmd" in
  list|"")
    echo "Available labs:"
    for d in "$LABS_ROOT"/*/; do
      echo "  $(basename "$d")"
    done
    echo
    echo "Run with: lab 01 | lab 02 | lab 03"
    echo "Working copies live under: $WORK_ROOT/<lab-name>/"
    ;;

  01|01-se-hello)
    prepare_workdir 01-se-hello
    make
    exec gem5-riscv run-se.py hello-se.elf
    ;;

  02|02-fs-linux-riscv)
    prepare_workdir 02-fs-linux-riscv
    # Fetch kernel + disk image directly from dist.gem5.org. We avoid the
    # gem5 example shipped under /opt/gem5/configs because it calls
    # obtain_resource(), which hits the gem5-resources metadata service.
    # That service returns HTTP 410 for v23.0.1.0 clients now, so the
    # shipped script crashes on startup.
    make artifacts
    echo "Booting Linux on HiFive (FS mode)."
    echo "When you see 'Listening for system connection on port 3456',"
    echo "open a SECOND terminal in this Codespace and run:"
    echo
    echo "    telnet localhost 3456"
    echo
    exec gem5-riscv run-fs.py
    ;;

  03|03-cpu-comparison)
    prepare_workdir 03-cpu-comparison
    exec python3 compare.py
    ;;

  shell|repl)
    exec bash
    ;;

  -h|--help|help)
    echo "usage: lab {list|01|02|03|shell}"
    ;;

  *)
    echo "lab: unknown command '$cmd'" >&2
    echo "usage: lab {list|01|02|03|shell}" >&2
    exit 1
    ;;
esac
